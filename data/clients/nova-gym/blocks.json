[
  {
    "id": "ng-header",
    "name": "Gym Header",
    "type": "header",
    "description": "Tmavý header s logem a sloganem",
    "html": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#0a0a0a;\">\n  <tr>\n    <td align=\"center\" style=\"padding:0;\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;\">\n        <tr>\n          <td align=\"left\" valign=\"middle\" style=\"padding:28px 30px 16px;\">\n            <span style=\"font-family:Arial,sans-serif;font-size:24px;font-weight:900;color:#ef4444;letter-spacing:-1px;\">NOVA</span><span style=\"font-family:Arial,sans-serif;font-size:24px;font-weight:900;color:#ffffff;letter-spacing:-1px;\"> GYM</span>\n          </td>\n          <td align=\"right\" valign=\"middle\" style=\"padding:28px 30px 16px;font-family:Arial,sans-serif;font-size:12px;color:#666666;\">\n            <a href=\"{{schedule_url}}\" style=\"color:#ef4444;text-decoration:none;font-weight:bold;\">Rozvrh hodin</a>\n            &nbsp;&nbsp;\n            <a href=\"{{membership_url}}\" style=\"color:#ffffff;text-decoration:none;\">Členství</a>\n          </td>\n        </tr>\n        <tr>\n          <td colspan=\"2\" style=\"height:3px;background:linear-gradient(90deg,#ef4444,#ff6b35);\"></td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>"
  },
  {
    "id": "ng-hero",
    "name": "Hero motivace",
    "type": "hero",
    "description": "Velký hero s motivačním textem a CTA",
    "html": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#0a0a0a;\">\n  <tr>\n    <td align=\"center\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;\">\n        <tr>\n          <td align=\"center\" style=\"padding:50px 30px;\">\n            <p style=\"font-family:Arial,sans-serif;font-size:12px;font-weight:bold;color:#ef4444;letter-spacing:3px;text-transform:uppercase;margin:0 0 16px;\">{{month}} {{year}}</p>\n            <h1 style=\"font-family:Arial,sans-serif;font-size:42px;font-weight:900;color:#ffffff;margin:0 0 16px;line-height:1.1;letter-spacing:-1px;\">{{headline}}</h1>\n            <p style=\"font-family:Arial,sans-serif;font-size:16px;color:#999999;margin:0 0 32px;line-height:1.6;\">{{subheadline}}</p>\n            <a href=\"{{cta_url}}\" style=\"display:inline-block;background:#ef4444;color:#ffffff;font-family:Arial,sans-serif;font-size:14px;font-weight:bold;text-decoration:none;padding:16px 36px;border-radius:3px;letter-spacing:1px;text-transform:uppercase;\">{{cta_text}}</a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>"
  },
  {
    "id": "ng-workout",
    "name": "Trénink týdne",
    "type": "content",
    "description": "Trénink týdne s popisem a parametry",
    "html": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#111111;\">\n  <tr>\n    <td align=\"center\" style=\"padding:40px 30px;\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;\">\n        <tr>\n          <td style=\"padding-bottom:24px;\">\n            <p style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#ef4444;letter-spacing:3px;text-transform:uppercase;margin:0 0 8px;\">Trénink týdne</p>\n            <h2 style=\"font-family:Arial,sans-serif;font-size:26px;font-weight:900;color:#ffffff;margin:0 0 12px;\">{{workout_name}}</h2>\n            <p style=\"font-family:Arial,sans-serif;font-size:14px;color:#888888;line-height:1.7;margin:0;\">{{workout_description}}</p>\n          </td>\n        </tr>\n        <tr>\n          <td>\n            <table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\n              <tr>\n                <td width=\"25%\" align=\"center\" style=\"background:#1a1a1a;border-radius:6px;padding:16px 8px;\">\n                  <p style=\"font-family:Arial,sans-serif;font-size:22px;font-weight:900;color:#ef4444;margin:0;\">{{sets}}</p>\n                  <p style=\"font-family:Arial,sans-serif;font-size:11px;color:#666666;margin:4px 0 0;text-transform:uppercase;letter-spacing:1px;\">série</p>\n                </td>\n                <td width=\"4%\"></td>\n                <td width=\"25%\" align=\"center\" style=\"background:#1a1a1a;border-radius:6px;padding:16px 8px;\">\n                  <p style=\"font-family:Arial,sans-serif;font-size:22px;font-weight:900;color:#ef4444;margin:0;\">{{reps}}</p>\n                  <p style=\"font-family:Arial,sans-serif;font-size:11px;color:#666666;margin:4px 0 0;text-transform:uppercase;letter-spacing:1px;\">opakování</p>\n                </td>\n                <td width=\"4%\"></td>\n                <td width=\"25%\" align=\"center\" style=\"background:#1a1a1a;border-radius:6px;padding:16px 8px;\">\n                  <p style=\"font-family:Arial,sans-serif;font-size:22px;font-weight:900;color:#ef4444;margin:0;\">{{rest}}</p>\n                  <p style=\"font-family:Arial,sans-serif;font-size:11px;color:#666666;margin:4px 0 0;text-transform:uppercase;letter-spacing:1px;\">odpočinek</p>\n                </td>\n                <td width=\"4%\"></td>\n                <td width=\"25%\" align=\"center\" style=\"background:#1a1a1a;border-radius:6px;padding:16px 8px;\">\n                  <p style=\"font-family:Arial,sans-serif;font-size:22px;font-weight:900;color:#ef4444;margin:0;\">{{duration}}</p>\n                  <p style=\"font-family:Arial,sans-serif;font-size:11px;color:#666666;margin:4px 0 0;text-transform:uppercase;letter-spacing:1px;\">minut</p>\n                </td>\n              </tr>\n            </table>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>"
  },
  {
    "id": "ng-classes",
    "name": "Rozvrh lekcí",
    "type": "content",
    "description": "Přehled nadcházejících lekcí",
    "html": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#0f0f0f;\">\n  <tr>\n    <td align=\"center\" style=\"padding:40px 30px;\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;\">\n        <tr>\n          <td style=\"padding-bottom:20px;\">\n            <h2 style=\"font-family:Arial,sans-serif;font-size:20px;font-weight:900;color:#ffffff;margin:0;letter-spacing:-0.5px;\">Nadcházející lekce</h2>\n          </td>\n        </tr>\n        <tr><td style=\"background:#1a1a1a;border-radius:8px;overflow:hidden;\">\n          <table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\n            <tr style=\"background:#222222;\">\n              <td style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#666666;padding:10px 16px;text-transform:uppercase;letter-spacing:1px;\">Lekce</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#666666;padding:10px 16px;text-transform:uppercase;letter-spacing:1px;\">Den &amp; čas</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#666666;padding:10px 16px;text-transform:uppercase;letter-spacing:1px;\">Lektor</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#666666;padding:10px 16px;\"></td>\n            </tr>\n            <tr style=\"border-bottom:1px solid #222222;\">\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#ffffff;padding:12px 16px;font-weight:bold;\">{{class_1_name}}</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;padding:12px 16px;\">{{class_1_time}}</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;padding:12px 16px;\">{{class_1_trainer}}</td>\n              <td style=\"padding:12px 16px;\"><a href=\"{{class_1_url}}\" style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#ef4444;text-decoration:none;\">Přihlásit</a></td>\n            </tr>\n            <tr style=\"border-bottom:1px solid #222222;\">\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#ffffff;padding:12px 16px;font-weight:bold;\">{{class_2_name}}</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;padding:12px 16px;\">{{class_2_time}}</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;padding:12px 16px;\">{{class_2_trainer}}</td>\n              <td style=\"padding:12px 16px;\"><a href=\"{{class_2_url}}\" style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#ef4444;text-decoration:none;\">Přihlásit</a></td>\n            </tr>\n            <tr>\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#ffffff;padding:12px 16px;font-weight:bold;\">{{class_3_name}}</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;padding:12px 16px;\">{{class_3_time}}</td>\n              <td style=\"font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;padding:12px 16px;\">{{class_3_trainer}}</td>\n              <td style=\"padding:12px 16px;\"><a href=\"{{class_3_url}}\" style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#ef4444;text-decoration:none;\">Přihlásit</a></td>\n            </tr>\n          </table>\n        </td></tr>\n      </table>\n    </td>\n  </tr>\n</table>"
  },
  {
    "id": "ng-quote",
    "name": "Motivační citát",
    "type": "content",
    "description": "Velký motivační citát s autorem",
    "html": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#ef4444;\">\n  <tr>\n    <td align=\"center\" style=\"padding:48px 40px;\">\n      <p style=\"font-family:Georgia,serif;font-size:26px;color:#ffffff;font-style:italic;line-height:1.4;margin:0 0 16px;\">&#8220;{{quote_text}}&#8221;</p>\n      <p style=\"font-family:Arial,sans-serif;font-size:13px;color:rgba(255,255,255,0.7);margin:0;font-weight:bold;letter-spacing:2px;text-transform:uppercase;\">— {{quote_author}}</p>\n    </td>\n  </tr>\n</table>"
  },
  {
    "id": "ng-offer",
    "name": "Speciální nabídka",
    "type": "hero",
    "description": "Zvýrazněná promo nabídka s kódem",
    "html": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#111111;\">\n  <tr>\n    <td align=\"center\" style=\"padding:40px 30px;\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;background:#1a1a1a;border:1px solid #333333;border-radius:8px;overflow:hidden;\">\n        <tr><td style=\"height:4px;background:linear-gradient(90deg,#ef4444,#ff6b35);\"></td></tr>\n        <tr>\n          <td align=\"center\" style=\"padding:36px 30px;\">\n            <p style=\"font-family:Arial,sans-serif;font-size:11px;font-weight:bold;color:#ef4444;letter-spacing:3px;text-transform:uppercase;margin:0 0 12px;\">Nabídka platí do {{offer_expiry}}</p>\n            <h2 style=\"font-family:Arial,sans-serif;font-size:28px;font-weight:900;color:#ffffff;margin:0 0 12px;\">{{offer_title}}</h2>\n            <p style=\"font-family:Arial,sans-serif;font-size:15px;color:#888888;margin:0 0 24px;line-height:1.6;\">{{offer_description}}</p>\n            <div style=\"display:inline-block;background:#0a0a0a;border:2px dashed #ef4444;border-radius:6px;padding:12px 28px;margin-bottom:24px;\">\n              <p style=\"font-family:'Courier New',monospace;font-size:20px;font-weight:bold;color:#ef4444;margin:0;letter-spacing:4px;\">{{promo_code}}</p>\n            </div>\n            <br>\n            <a href=\"{{offer_url}}\" style=\"display:inline-block;background:#ef4444;color:#ffffff;font-family:Arial,sans-serif;font-size:13px;font-weight:bold;text-decoration:none;padding:14px 32px;border-radius:3px;text-transform:uppercase;letter-spacing:1px;\">{{offer_cta}}</a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>"
  },
  {
    "id": "ng-footer",
    "name": "Gym Footer",
    "type": "footer",
    "description": "Patička s adresou a sociálními sítěmi",
    "html": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#0a0a0a;border-top:3px solid #ef4444;\">\n  <tr>\n    <td align=\"center\" style=\"padding:32px 30px;\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;\">\n        <tr>\n          <td align=\"center\" style=\"padding-bottom:16px;\">\n            <span style=\"font-family:Arial,sans-serif;font-size:18px;font-weight:900;color:#ef4444;\">NOVA</span><span style=\"font-family:Arial,sans-serif;font-size:18px;font-weight:900;color:#ffffff;\"> GYM</span>\n          </td>\n        </tr>\n        <tr>\n          <td align=\"center\" style=\"font-family:Arial,sans-serif;font-size:12px;color:#555555;line-height:1.8;padding-bottom:16px;\">\n            {{gym_address}}<br>\n            <a href=\"tel:{{gym_phone}}\" style=\"color:#555555;text-decoration:none;\">{{gym_phone}}</a> &nbsp;&middot;&nbsp;\n            <a href=\"mailto:{{gym_email}}\" style=\"color:#555555;text-decoration:none;\">{{gym_email}}</a>\n          </td>\n        </tr>\n        <tr>\n          <td align=\"center\" style=\"font-family:Arial,sans-serif;font-size:11px;color:#444444;\">\n            <a href=\"{{unsubscribe_url}}\" style=\"color:#444444;text-decoration:underline;\">Odhlásit odběr</a>\n            &nbsp;&middot;&nbsp;\n            <a href=\"{{webview_url}}\" style=\"color:#444444;text-decoration:underline;\">Zobrazit v prohlížeči</a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>"
  }
]
