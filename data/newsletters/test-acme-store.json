      "variables": {
        "logo_text": "Acme Store",
        "nav_link_1_url": "#",
        "nav_link_1": "Novinky",
        "nav_link_2_url": "#",
        "nav_link_2": "Výprodej",
        "nav_link_3_url": "#",
        "nav_link_3": "Kontakt"
      }
    },
    {
      "instanceId": "text-block-1",
