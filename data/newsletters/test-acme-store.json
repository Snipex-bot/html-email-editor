      "name": "Patička",
      "type": "footer",
      "rawTemplate": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#111111;\">\n  <tr>\n    <td align=\"center\" style=\"padding:32px 20px;\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;\">\n        <tr>\n          <td align=\"center\" style=\"font-family:Arial,sans-serif;font-size:13px;color:#aaaaaa;line-height:1.8;\">\n            <p style=\"margin:0 0 8px;font-weight:bold;color:#ffffff;\">{{company_name}}</p>\n            <p style=\"margin:0 0 16px;\">{{company_address}}</p>\n            <p style=\"margin:0;\">\n              <a href=\"{{unsubscribe_url}}\" style=\"color:#aaaaaa;text-decoration:underline;\">Odhlásit odběr</a>\n              &nbsp;&middot;&nbsp;\n              <a href=\"{{webview_url}}\" style=\"color:#aaaaaa;text-decoration:underline;\">Zobrazit v prohlížeči</a>\n            </p>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>",
