      "name": "Textový blok",
      "type": "content",
      "rawTemplate": "<table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"background:#ffffff;\">\n  <tr>\n    <td align=\"center\" style=\"padding:32px 30px;\">\n      <table width=\"600\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\" style=\"max-width:600px;\">\n        <tr>\n          <td style=\"font-family:Arial,sans-serif;font-size:15px;color:#444444;line-height:1.7;\">\n            <h2 style=\"font-size:22px;color:#111111;margin:0 0 14px;\">{{section_heading}}</h2>\n            <p style=\"margin:0;\">{{body_text}}</p>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>",
      "variables": {
        "section_heading": "Vítejte v dubnovém vydání!",
        "body_text": "Děkujeme, že jste součástí naší komunity. Tento měsíc pro vás máme spoustu zajímavých novinek a speciálních nabídek."
      }
    },
    {
